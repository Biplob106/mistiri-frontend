# Backend API base URL (must include the /api prefix).
# Local dev: copy this file to .env.local and keep localhost.
# Production/Preview values are set in Vercel → Project → Settings → Environment Variables.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Google Sign-In (optional). Client ID from Google Cloud Console → OAuth 2.0 Client.
# Add your site to "Authorized JavaScript origins". Leave unset to hide the button.
# The same ID must also be set as GOOGLE_CLIENT_ID on the backend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
